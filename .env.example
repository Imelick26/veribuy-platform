# VeriBuy Platform — copy to .env.local and fill in real values

# ─── Database (Supabase PostgreSQL) ───
# Get from: Supabase Dashboard → Project Settings → Database → Connection string → URI
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"

# ─── Auth ───
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# ─── External APIs ───
# NHTSA APIs are free, no key needed
# NHTSA_API_URL="https://vpic.nhtsa.dot.gov/api/vehicles"

# ─── AWS (Media Storage — Phase 3) ───
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION="us-west-2"
# S3_BUCKET="veribuy-media"
# CLOUDFRONT_URL=""

# ─── AI (Phase 3) ───
# OPENAI_API_KEY=""

# ─── Email (Resend — landing site contact forms) ───
# Get from: https://resend.com/api-keys
# RESEND_API_KEY=""
# CONTACT_EMAIL_1=""
# CONTACT_EMAIL_2=""

# ─── Background Jobs (Phase 3) ───
# INNGEST_EVENT_KEY=""
# INNGEST_SIGNING_KEY=""

# ─── Blockchain (Phase 5) ───
# POLYGON_RPC_URL=""
# POLYGON_PRIVATE_KEY=""
# VERIBUY_ANCHOR_CONTRACT=""
