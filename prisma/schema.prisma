// VeriBuy Platform — Prisma Schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ═══════════════════════════════════════════════════════════════
//  Authentication & Multi-tenancy
// ═══════════════════════════════════════════════════════════════

model Organization {
  id           String           @id @default(cuid())
  name         String
  slug         String           @unique
  type         OrgType
  logo         String?
  address      String?
  city         String?
  state        String?
  zip          String?
  phone        String?
  website      String?
  subscription           SubscriptionTier @default(BASE)
  maxInspectionsPerMonth Int              @default(25)
  bonusInspections       Int              @default(0)

  // Stripe subscription billing
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  stripePriceId        String?
  subscriptionStatus   String?  // "active" | "past_due" | "cancelled" | "trialing"
  currentPeriodEnd     DateTime?

  users          User[]
  vehicles       Vehicle[]
  inspections    Inspection[]
  reports        Report[]
  packPurchases  InspectionPackPurchase[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum OrgType {
  DEALER
  INSPECTOR_FIRM
  INSURANCE
  INDIVIDUAL
}

enum SubscriptionTier {
  BASE
  PRO
  ENTERPRISE
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String?
  avatar       String?
  role         UserRole @default(INSPECTOR)

  orgId String
  org   Organization @relation(fields: [orgId], references: [id])

  inspections Inspection[]
  auditLogs   AuditLog[]

  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  @@index([orgId])
}

enum UserRole {
  SUPER_ADMIN
  OWNER
  MANAGER
  INSPECTOR
  VIEWER
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ═══════════════════════════════════════════════════════════════
//  Billing — Inspection Pack Purchases
// ═══════════════════════════════════════════════════════════════

model InspectionPackPurchase {
  id              String   @id @default(cuid())
  orgId           String
  org             Organization @relation(fields: [orgId], references: [id])
  stripeSessionId String   @unique
  packSize        Int
  amountCents     Int
  status          String   @default("pending")
  purchasedById   String?
  createdAt       DateTime @default(now())
  completedAt     DateTime?

  @@index([orgId])
  @@index([stripeSessionId])
}

// ═══════════════════════════════════════════════════════════════
//  Vehicle Intelligence
// ═══════════════════════════════════════════════════════════════

model Vehicle {
  id            String  @id @default(cuid())
  vin           String  @unique
  year          Int
  make          String
  model         String
  trim          String?
  bodyStyle     String?
  drivetrain    String?
  engine        String?
  transmission  String?
  exteriorColor String?
  interiorColor String?
  msrp          Int?

  nhtsaData Json?

  orgId String
  org   Organization @relation(fields: [orgId], references: [id])

  inspections Inspection[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vin])
  @@index([orgId])
  @@index([make, model, year])
}

// ═══════════════════════════════════════════════════════════════
//  Inspection Workflow
// ═══════════════════════════════════════════════════════════════

model Inspection {
  id     String           @id @default(cuid())
  number String           @unique
  status InspectionStatus @default(CREATED)

  odometer Int?
  location String?
  notes    String?

  overallScore         Int?
  exteriorBodyScore    Int?    // 1-10 AI condition assessment
  interiorScore        Int?    // 1-10 AI condition assessment
  mechanicalVisualScore Int?   // 1-10 AI condition assessment
  underbodyFrameScore  Int?    // 1-10 AI condition assessment
  conditionSummary     String? // AI-generated condition summary
  conditionRawData     Json?   // Full AI response for audit trail

  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])

  inspectorId String
  inspector   User @relation(fields: [inspectorId], references: [id])

  orgId String
  org   Organization @relation(fields: [orgId], references: [id])

  steps          InspectionStep[]
  findings       Finding[]
  media          MediaItem[]
  marketAnalysis MarketAnalysis?
  vehicleHistory VehicleHistory?
  report         Report?

  startedAt   DateTime  @default(now())
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([orgId, status])
  @@index([vehicleId])
  @@index([inspectorId])
  @@index([number])
}

enum InspectionStatus {
  CREATED
  VIN_DECODED
  RISK_REVIEWED
  MEDIA_CAPTURE
  AI_ANALYZED
  MARKET_PRICED
  REVIEWED
  COMPLETED
  CANCELLED
}

model InspectionStep {
  id     String       @id @default(cuid())
  step   WorkflowStep
  status StepStatus   @default(PENDING)
  data   Json?

  inspectionId String
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  enteredAt   DateTime?
  completedAt DateTime?

  @@unique([inspectionId, step])
}

enum WorkflowStep {
  // Active workflow steps (new flow)
  MEDIA_CAPTURE
  VIN_CONFIRM
  AI_CONDITION_SCAN
  RISK_INSPECTION
  VEHICLE_HISTORY
  MARKET_ANALYSIS
  REPORT_GENERATION
  // Deprecated (kept for backward compat with existing inspections)
  VIN_DECODE
  RISK_REVIEW
  AI_ANALYSIS
}

enum StepStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

// ═══════════════════════════════════════════════════════════════
//  Findings
// ═══════════════════════════════════════════════════════════════

model Finding {
  id          String          @id @default(cuid())
  severity    Severity
  category    FindingCategory
  title       String
  description String
  evidence    String?
  impact      String?

  repairCostLow  Int?
  repairCostHigh Int?

  positionX Float?
  positionY Float?
  positionZ Float?

  inspectionId String
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  media MediaItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([inspectionId])
  @@index([severity])
}

enum Severity {
  CRITICAL
  MAJOR
  MODERATE
  MINOR
  INFO
}

enum FindingCategory {
  STRUCTURAL
  DRIVETRAIN
  ENGINE
  TRANSMISSION
  ELECTRICAL
  COSMETIC_EXTERIOR
  COSMETIC_INTERIOR
  ELECTRONICS
  SAFETY
  TIRES_WHEELS
  BRAKES
  SUSPENSION
  HVAC
  OTHER
}

// ═══════════════════════════════════════════════════════════════
//  Media
// ═══════════════════════════════════════════════════════════════

model MediaItem {
  id          String       @id @default(cuid())
  type        MediaType
  captureType String?       // Free-form: standard shots + dynamic like FINDING_EVIDENCE_riskId_0

  s3Key        String
  s3Bucket     String @default("veribuy-media")
  url          String
  thumbnailUrl String?

  mimeType   String
  sizeBytes  Int
  width      Int?
  height     Int?
  durationMs Int?
  exifData   Json?

  qualityScore Int?
  aiAnalysis   Json?

  inspectionId String
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  findingId String?
  finding   Finding? @relation(fields: [findingId], references: [id])

  createdAt DateTime @default(now())

  @@index([inspectionId])
  @@index([findingId])
}

enum MediaType {
  PHOTO
  VIDEO
  AUDIO
}

enum CaptureType {
  // Exterior (9)
  FRONT_CENTER
  FRONT_34_DRIVER
  FRONT_34_PASSENGER
  DRIVER_SIDE
  REAR_34_DRIVER
  REAR_34_PASSENGER
  REAR_CENTER
  PASSENGER_SIDE
  ROOF
  // Interior (4)
  DASHBOARD_DRIVER
  FRONT_SEATS
  REAR_SEATS
  CARGO_AREA
  // Mechanical (6)
  ENGINE_BAY
  UNDERCARRIAGE
  TIRE_FRONT_DRIVER
  TIRE_REAR_DRIVER
  TIRE_FRONT_PASSENGER
  TIRE_REAR_PASSENGER
  // Identification (4)
  UNDER_HOOD_LABEL
  VIN_PLATE
  DOOR_JAMB_DRIVER
  ODOMETER
  // Legacy / other
  WALKAROUND_VIDEO
  ENGINE_AUDIO
  INTERIOR_WALKTHROUGH
  FINDING_EVIDENCE
  OTHER
}

// ═══════════════════════════════════════════════════════════════
//  Market Intelligence
// ═══════════════════════════════════════════════════════════════

model MarketAnalysis {
  id String @id @default(cuid())

  comparables   Json
  baselinePrice Int      // VinAudit estimated value (cents)
  adjustments   Json
  adjustedPrice Int      // Final fair market value for THIS car (cents)

  recommendation BuyRecommendation
  strongBuyMax   Int
  fairBuyMax     Int

  estRetailPrice Int?
  estReconCost   Int?
  estGrossProfit Int?

  // Valuation breakdown (from market-valuation.ts engine)
  conditionScore           Int?
  conditionMultiplier      Float?
  conditionGrade           String?   // "EXCELLENT" | "VERY_GOOD" | "GOOD" | "FAIR" | "POOR" | "SALVAGE"
  historyMultiplier        Float?
  historyBreakdown         Json?     // { titleFactor, accidentFactor, ownerFactor, structuralDamageFactor, floodDamageFactor, recallFactor }
  fairValueAtBaseline      Int?      // Fair value at score=85 (good condition reference) in cents
  adjustedValueBeforeRecon Int?      // After condition+history, before recon subtracted (cents)
  overpayingMax            Int?      // PASS threshold price (cents)
  priceBands               Json?     // [{ label, maxPriceCents, marginPercent }]

  inspectionId String     @unique
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  fetchedAt DateTime @default(now())

  @@index([inspectionId])
}

enum BuyRecommendation {
  STRONG_BUY
  FAIR_BUY
  OVERPAYING
  PASS
}

// ═══════════════════════════════════════════════════════════════
//  Vehicle History
// ═══════════════════════════════════════════════════════════════

model VehicleHistory {
  id String @id @default(cuid())

  provider         String
  titleStatus      String
  accidentCount    Int     @default(0)
  serviceRecords   Int     @default(0)
  ownerCount       Int?
  structuralDamage Boolean @default(false)
  floodDamage      Boolean @default(false)

  rawData         Json?
  recalls         Json?
  openRecallCount Int @default(0)

  inspectionId String     @unique
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  fetchedAt DateTime @default(now())
}

// ═══════════════════════════════════════════════════════════════
//  Reports
// ═══════════════════════════════════════════════════════════════

model Report {
  id     String @id @default(cuid())
  number String @unique

  pdfS3Key String?
  pdfUrl   String?

  shareToken     String?   @unique
  sharePassword  String?
  shareExpiresAt DateTime?
  viewCount      Int       @default(0)

  blockchainHash String?
  blockchainTxId String?
  anchoredAt     DateTime?

  inspectionId String     @unique
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  orgId String
  org   Organization @relation(fields: [orgId], references: [id])

  generatedAt DateTime @default(now())

  @@index([shareToken])
  @@index([orgId])
}

// ═══════════════════════════════════════════════════════════════
//  Audit Trail
// ═══════════════════════════════════════════════════════════════

model AuditLog {
  id         String @id @default(cuid())
  action     String
  entityType String
  entityId   String
  metadata   Json?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════════
//  Risk Intelligence (Reference Data)
// ═══════════════════════════════════════════════════════════════

model RiskProfile {
  id String @id @default(cuid())

  make     String
  model    String
  yearFrom Int
  yearTo   Int
  engine   String?

  risks  Json
  source String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([make, model])
}
