// VeriBuy Platform — Prisma Schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ═══════════════════════════════════════════════════════════════
//  Authentication & Multi-tenancy
// ═══════════════════════════════════════════════════════════════

model Organization {
  id           String           @id @default(cuid())
  name         String
  slug         String           @unique
  type         OrgType
  logo         String?
  address      String?
  city         String?
  state        String?
  zip          String?
  phone        String?
  website      String?
  subscription           SubscriptionTier @default(BASE)
  maxInspectionsPerMonth Int              @default(25)
  bonusInspections       Int              @default(0)

  // Pricing preferences
  targetMarginPercent  Int      @default(20) // Dealer target margin percentage (e.g., 20 = 20%)
  minProfitPerUnit     Int      @default(150000) // Minimum profit per vehicle in cents ($1,500)

  // Stripe subscription billing
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  stripePriceId        String?
  subscriptionStatus   String?  // "active" | "past_due" | "cancelled" | "trialing"
  currentPeriodEnd     DateTime?

  users          User[]
  vehicles       Vehicle[]
  inspections    Inspection[]
  reports        Report[]
  packPurchases  InspectionPackPurchase[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum OrgType {
  DEALER
  INSPECTOR_FIRM
  INSURANCE
  INDIVIDUAL
}

enum SubscriptionTier {
  BASE
  PRO
  ENTERPRISE
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String?
  avatar       String?
  role         UserRole @default(INSPECTOR)

  orgId String
  org   Organization @relation(fields: [orgId], references: [id])

  inspections Inspection[]
  auditLogs   AuditLog[]

  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  @@index([orgId])
}

enum UserRole {
  SUPER_ADMIN
  OWNER
  MANAGER
  INSPECTOR
  VIEWER
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ═══════════════════════════════════════════════════════════════
//  Billing — Inspection Pack Purchases
// ═══════════════════════════════════════════════════════════════

model InspectionPackPurchase {
  id              String   @id @default(cuid())
  orgId           String
  org             Organization @relation(fields: [orgId], references: [id])
  stripeSessionId String   @unique
  packSize        Int
  amountCents     Int
  status          String   @default("pending")
  purchasedById   String?
  createdAt       DateTime @default(now())
  completedAt     DateTime?

  @@index([orgId])
  @@index([stripeSessionId])
}

// ═══════════════════════════════════════════════════════════════
//  Vehicle Intelligence
// ═══════════════════════════════════════════════════════════════

model Vehicle {
  id            String  @id @default(cuid())
  vin           String  @unique
  year          Int
  make          String
  model         String
  trim          String?
  bodyStyle     String?
  drivetrain    String?
  engine        String?
  transmission  String?
  exteriorColor String?
  interiorColor String?
  msrp          Int?

  nhtsaData Json?

  orgId String
  org   Organization @relation(fields: [orgId], references: [id])

  inspections Inspection[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vin])
  @@index([orgId])
  @@index([make, model, year])
}

// ═══════════════════════════════════════════════════════════════
//  Inspection Workflow
// ═══════════════════════════════════════════════════════════════

model Inspection {
  id     String           @id @default(cuid())
  number String           @unique
  status InspectionStatus @default(CREATED)

  odometer Int?
  location String?
  notes    String?

  overallScore         Int?
  // Legacy 4-area scores (backward compat — computed from 9-bucket scores)
  exteriorBodyScore    Int?    // 1-10 avg of paintBody + panelAlignment + glassLighting
  interiorScore        Int?    // 1-10 avg of interiorSurfaces + interiorControls
  mechanicalVisualScore Int?   // 1-10 avg of engineBay + tiresWheels + exhaust
  underbodyFrameScore  Int?    // 1-10 (same as 9-bucket underbodyFrame)
  // 9-bucket detailed condition scores (1-10 each)
  paintBodyScore       Int?    // Dents, scratches, rust, paint chips, fade, respray
  panelAlignmentScore  Int?    // Gap asymmetry, bumper fitment, collision evidence
  glassLightingScore   Int?    // Windshield, headlights, taillights, mirrors
  interiorSurfacesScore Int?   // Seats, carpet, headliner, door panels, steering wheel
  interiorControlsScore Int?   // Infotainment, HVAC, gauges, switches
  engineBayScore       Int?    // Leaks, belts, hoses, battery, aftermarket
  tiresWheelsScore     Int?    // Tread, sidewalls, rims, wear patterns
  // underbodyFrameScore reused from legacy (frame rails, rust, suspension)
  exhaustScore         Int?    // Pipes, muffler, catalytic converter, hangers
  conditionWeights     Json?   // AI-determined per-vehicle weights { paintBody: 15, ... }
  conditionSummary     String? // AI-generated condition summary
  conditionRawData     Json?   // Full AI response for audit trail

  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])

  inspectorId String
  inspector   User @relation(fields: [inspectorId], references: [id])

  orgId String
  org   Organization @relation(fields: [orgId], references: [id])

  steps          InspectionStep[]
  findings       Finding[]
  media          MediaItem[]
  marketAnalysis  MarketAnalysis?
  vehicleHistory  VehicleHistory?
  report          Report?
  aiValuationLogs ValuationLog[]

  // Dealer offer customization — explains gap between VeriBuy valuation and dealer's offer
  offerMode           String?     // "AI_ESTIMATED" | "CUSTOM_NOTES" — how the gap is explained to seller
  offerNotes          String?     // Free-text dealer notes shown on seller report when mode = CUSTOM_NOTES
  offerCostBreakdown  Json?       // AI-computed cost decomposition when mode = AI_ESTIMATED

  // Outcome tracking (training data for AI accuracy)
  purchaseOutcome     String?     // "PURCHASED" | "PASSED" | null (not yet answered)
  purchasePrice       Int?        // cents — what they actually paid
  outcomeRecordedAt   DateTime?   // when they logged the outcome
  outcomeEmailSent    Boolean     @default(false) // prevent duplicate follow-up emails

  startedAt   DateTime  @default(now())
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([orgId, status])
  @@index([vehicleId])
  @@index([inspectorId])
  @@index([number])
}

enum InspectionStatus {
  CREATED
  VIN_DECODED
  CONDITION_REVIEWED
  RISK_REVIEWED
  MEDIA_CAPTURE
  AI_ANALYZED
  MARKET_PRICED
  REVIEWED
  COMPLETED
  CANCELLED
}

model InspectionStep {
  id     String       @id @default(cuid())
  step   WorkflowStep
  status StepStatus   @default(PENDING)
  data   Json?

  inspectionId String
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  enteredAt   DateTime?
  completedAt DateTime?

  @@unique([inspectionId, step])
}

enum WorkflowStep {
  // Active workflow steps (new flow)
  MEDIA_CAPTURE
  VIN_CONFIRM
  AI_CONDITION_SCAN
  CONDITION_REVIEW
  RISK_INSPECTION
  VEHICLE_HISTORY
  MARKET_ANALYSIS
  REPORT_GENERATION
  // Deprecated (kept for backward compat with existing inspections)
  VIN_DECODE
  RISK_REVIEW
  AI_ANALYSIS
}

enum StepStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

// ═══════════════════════════════════════════════════════════════
//  Findings
// ═══════════════════════════════════════════════════════════════

model Finding {
  id          String          @id @default(cuid())
  severity    Severity
  category    FindingCategory
  title       String
  description String
  evidence    String?
  impact      String?

  repairCostLow  Int?
  repairCostHigh Int?

  positionX Float?
  positionY Float?
  positionZ Float?

  inspectionId String
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  media MediaItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([inspectionId])
  @@index([severity])
}

enum Severity {
  CRITICAL
  MAJOR
  MODERATE
  MINOR
  INFO
}

enum FindingCategory {
  STRUCTURAL
  DRIVETRAIN
  ENGINE
  TRANSMISSION
  ELECTRICAL
  COSMETIC_EXTERIOR
  COSMETIC_INTERIOR
  ELECTRONICS
  SAFETY
  TIRES_WHEELS
  BRAKES
  SUSPENSION
  HVAC
  OTHER
}

// ═══════════════════════════════════════════════════════════════
//  Media
// ═══════════════════════════════════════════════════════════════

model MediaItem {
  id          String       @id @default(cuid())
  type        MediaType
  captureType String?       // Free-form: standard shots + dynamic like FINDING_EVIDENCE_riskId_0

  s3Key        String
  s3Bucket     String @default("veribuy-media")
  url          String
  thumbnailUrl String?
  uploadStatus UploadStatus @default(PENDING)

  mimeType   String
  sizeBytes  Int
  width      Int?
  height     Int?
  durationMs Int?
  exifData   Json?

  qualityScore Int?
  aiAnalysis   Json?

  inspectionId String
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  findingId String?
  finding   Finding? @relation(fields: [findingId], references: [id])

  createdAt DateTime @default(now())

  @@index([inspectionId])
  @@index([findingId])
}

enum UploadStatus {
  PENDING
  CONFIRMED
  FAILED
}

enum MediaType {
  PHOTO
  VIDEO
  AUDIO
}

enum CaptureType {
  // Exterior (9)
  FRONT_CENTER
  FRONT_34_DRIVER
  FRONT_34_PASSENGER
  DRIVER_SIDE
  REAR_34_DRIVER
  REAR_34_PASSENGER
  REAR_CENTER
  PASSENGER_SIDE
  ROOF
  // Interior (4)
  DASHBOARD_DRIVER
  FRONT_SEATS
  REAR_SEATS
  CARGO_AREA
  // Mechanical (6)
  ENGINE_BAY
  UNDERCARRIAGE
  TIRE_FRONT_DRIVER
  TIRE_REAR_DRIVER
  TIRE_FRONT_PASSENGER
  TIRE_REAR_PASSENGER
  // Identification (4)
  UNDER_HOOD_LABEL
  VIN_PLATE
  DOOR_JAMB_DRIVER
  ODOMETER
  // Legacy / other
  WALKAROUND_VIDEO
  ENGINE_AUDIO
  INTERIOR_WALKTHROUGH
  FINDING_EVIDENCE
  OTHER
}

// ═══════════════════════════════════════════════════════════════
//  Market Intelligence
// ═══════════════════════════════════════════════════════════════

model MarketAnalysis {
  id String @id @default(cuid())

  comparables   Json
  baselinePrice Int      // VinAudit estimated value (cents)
  adjustments   Json
  adjustedPrice Int      // Final fair market value for THIS car (cents)

  recommendation BuyRecommendation
  strongBuyMax   Int
  fairBuyMax     Int

  estRetailPrice Int?
  estReconCost   Int?
  estGrossProfit Int?

  // Valuation breakdown (from market-valuation.ts engine)
  conditionScore           Int?
  conditionMultiplier      Float?
  conditionGrade           String?   // "EXCELLENT" | "VERY_GOOD" | "GOOD" | "FAIR" | "POOR" | "SALVAGE"
  historyMultiplier        Float?
  historyBreakdown         Json?     // { titleFactor, accidentFactor, ownerFactor, structuralDamageFactor, floodDamageFactor, recallFactor }
  fairValueAtBaseline      Int?      // Fair value at score=85 (good condition reference) in cents
  adjustedValueBeforeRecon Int?      // After condition+history, before recon subtracted (cents)
  overpayingMax            Int?      // PASS threshold price (cents)
  priceBands               Json?     // [{ label, maxPriceCents, marginPercent }]

  // Data source + configuration premiums (multi-source pricing)
  dataSource            String?   // "nada" | "vehicledatabases" | "vinaudit" | "marketcheck" | "fallback" | "consensus"
  dataSourceConfidence  Float?    // 0.0-1.0 confidence in the base price
  configPremiums        Json?     // [{ factor, multiplier, explanation }]
  configMultiplier      Float?    // Combined config premium multiplier
  baseValuePreConfig    Int?      // Base value before config premiums applied (cents)

  // Three-perspective pricing (cents) — from VehicleDatabases/NADA or derived
  tradeInValue          Int?
  privatePartyValue     Int?
  dealerRetailValue     Int?

  // Condition tier used for VehicleDatabases lookup
  vdbConditionTier      String?   // "Outstanding" | "Clean" | "Average" | "Rough"

  // Wholesale + loan values (cents) — from BlackBook/NADA
  wholesaleValue        Int?
  loanValue             Int?

  // Multi-source consensus metadata
  sourceResults         Json?     // [{ source, estimatedValue, confidence, ... }]
  consensusMethod       String?   // "single" | "weighted-median" | "fallback"
  configPremiumMode     String?   // "full" | "partial" | "none"
  conditionAttenuation  Float?    // 0-1, how much condition multiplier applies
  sourceCount           Int?      // Number of pricing sources that contributed data

  // AI auditor result
  aiAuditorApproved     Boolean?  // true = coherent, false = adjusted
  aiAuditorCoherence    Float?    // 0-1 coherence score
  aiAuditorFlags        Json?     // string[] of issues found
  aiAuditorReasoning    String?   @db.Text

  inspectionId String     @unique
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  fetchedAt DateTime @default(now())

  @@index([inspectionId])
}

enum BuyRecommendation {
  STRONG_BUY
  FAIR_BUY
  OVERPAYING
  PASS
}

// ═══════════════════════════════════════════════════════════════
//  AI Valuation Log — training data for continuous improvement
// ═══════════════════════════════════════════════════════════════

model ValuationLog {
  id String @id @default(cuid())

  inspectionId String
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  // Which AI module produced this result
  module    String  // "consensus" | "config_premium" | "geo_pricing" | "history" | "condition" | "recon" | "deal_rating" | "auditor"
  model     String  // "gpt-4o" | "gpt-4o-mini" | "heuristic"

  // Reliability tier: 1=primary, 2=simplified AI fallback, 3=emergency heuristic
  fallbackTier Int
  retried      Boolean @default(false)

  // The full input context sent to the AI
  input  Json
  // The full output received from the AI
  output Json
  // AI reasoning text
  reasoning String? @db.Text

  // For the auditor specifically
  auditorApproved    Boolean?
  auditorCoherence   Float?
  auditorFlags       Json?     // string[]
  auditorAdjustment  Int?      // cents — how much the price was adjusted

  // Timing
  durationMs Int?
  createdAt  DateTime @default(now())

  @@index([inspectionId])
  @@index([module])
  @@index([fallbackTier])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════════
//  Vehicle History
// ═══════════════════════════════════════════════════════════════

model VehicleHistory {
  id String @id @default(cuid())

  provider         String
  titleStatus      String
  accidentCount    Int     @default(0)
  serviceRecords   Int     @default(0)
  ownerCount       Int?
  structuralDamage Boolean @default(false)
  floodDamage      Boolean @default(false)

  rawData         Json?
  recalls         Json?
  openRecallCount Int @default(0)

  inspectionId String     @unique
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  fetchedAt DateTime @default(now())
}

// ═══════════════════════════════════════════════════════════════
//  Reports
// ═══════════════════════════════════════════════════════════════

model Report {
  id     String @id @default(cuid())
  number String @unique

  pdfS3Key String?
  pdfUrl   String?

  shareToken     String?   @unique
  sharePassword  String?
  shareExpiresAt DateTime?
  viewCount      Int       @default(0)

  blockchainHash String?
  blockchainTxId String?
  anchoredAt     DateTime?

  inspectionId String     @unique
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  orgId String
  org   Organization @relation(fields: [orgId], references: [id])

  generatedAt DateTime @default(now())

  @@index([shareToken])
  @@index([orgId])
}

// ═══════════════════════════════════════════════════════════════
//  Audit Trail
// ═══════════════════════════════════════════════════════════════

model AuditLog {
  id         String @id @default(cuid())
  action     String
  entityType String
  entityId   String
  metadata   Json?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════════
//  Risk Intelligence (Reference Data)
// ═══════════════════════════════════════════════════════════════

model RiskProfile {
  id String @id @default(cuid())

  make     String
  model    String
  yearFrom Int
  yearTo   Int
  engine   String?

  risks  Json
  source String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([make, model])
}
